---
import { getEntry, render } from 'astro:content';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Avatar from '../components/Avatar.astro';
import Header from '../components/Header.astro';
import SocialLinks from '../components/SocialLinks.astro';
import WorksList from '../components/WorksList.astro';
import Modal from '../components/Modal.astro';
import { pageTitle, site } from '../data/seo';


const about = await getEntry('about', 'index');
if (!about) throw new Error('About content missing');
const { Content } = await render(about);

const works = await getCollection('works');

const socials = [
  { label: 'Github', href: 'https://github.com/eigdoyr' },
  { label: 'Dribbble', href: 'https://dribbble.com/ryodgie' },
  { label: 'Linkedin', href: 'https://www.linkedin.com/in/ryodgie/' },
  { label: 'Email', href: 'mailto:hello@ryodgie.com' },
];

const v1 = { label: "'folio v1", href: 'https://ryodgie-portfolio-v1.vercel.app' };



---

<Layout title={pageTitle()} description={site.description}>
  <Avatar src="/profile.png" alt="Ryodgie Barnatia" />
  <div class="header-wrap">
    <Header
      name="Ryodgie Barnatia"
      role="Web / UI Designer & Front-end Developer."
    />
  </div>

  <div class="about">
    <Content />
  </div>

  <hr class="divider" />

  <WorksList />

  <hr class="divider" />

  <div class="socials-wrap">
    <SocialLinks links={socials} v1={v1} />
  </div>
{
    works.map((entry) => (
      <template data-project={entry.id}>
        <span data-field="title">{entry.data.title}</span>
        <span data-field="desc">{entry.data.description}</span>
        <span data-field="link">{entry.data.link ?? ''}</span>
        <div data-field="images">
          {entry.data.images.map((img) => (
            <Image
              src={img}
              alt={entry.data.title}
              widths={[600, 1200]}
              sizes="(max-width: 768px) 90vw, 592px"
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
      </template>
    ))
  }

  <Modal />
  <Modal />
</Layout>

<style lang="scss">
  .header-wrap {
    margin-top: $space-s;
  }

  .about {
    margin-top: $space-m;
    color: $color-text-muted;
    font-family: $font-sans;
    font-size: $text-base;
    line-height: $leading-normal;

    > :global(p) + :global(p) {
      margin-top: $space-s;
    }
  }

 .divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.1);
  border: none;
  margin: $space-m 0;
}

  .socials-wrap {
    // no top margin — the divider above provides the spacing
  }

  // ---- Entrance ----
// Each top-level section fades up, staggered. Plays once on load.
:global(.avatar-wrap),
:global(.header-wrap),
.about,
:global(.divider),
:global(.works),
:global(.socials-wrap) {
  opacity: 0;
  transform: translateY(12px);
  animation: fadeUp $duration-base $ease-out-soft forwards;
}

:global(.avatar-wrap) {
  animation-delay: 0ms;
}

:global(.header-wrap) {
  animation-delay: 80ms;
}

.about {
  animation-delay: 160ms;
}

:global(.divider):first-of-type {
  animation-delay: 240ms;
}

:global(.works) {
  animation-delay: 320ms;
}

:global(.divider):last-of-type {
  animation-delay: 400ms;
}

:global(.socials-wrap) {
  animation-delay: 480ms;
}

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (prefers-reduced-motion: reduce) {
  :global(.avatar-wrap),
  :global(.header-wrap),
  .about,
  :global(.divider),
  :global(.works),
  :global(.socials-wrap) {
    opacity: 1;
    transform: none;
    animation: none;
  }
}
</style>