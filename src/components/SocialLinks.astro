---
interface SocialLink {
  label: string;
  href: string;
}

interface Props {
  links: SocialLink[];
  v1?: { label: string; href: string };
}

const { links, v1 } = Astro.props;
---

<ul class="socials">
  {
    links.map(({ label, href }) => {
      const isEmail = href.startsWith('mailto:');
      return (
        <li>
          
          <a  href={href}
            target={isEmail ? undefined : '_blank'}
            rel={isEmail ? undefined : 'noopener noreferrer'}
          >
            {label}
          </a>
        </li>
      );
    })
  }

  {
    v1 && (
      <li class="v1">
        <a href={v1.href} target="_blank" rel="noopener noreferrer">
          {v1.label} &rarr;
        </a>
      </li>
    )
  }
</ul>

<style lang="scss">
  .socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: $space-m;
    list-style: none;
    padding: 0;
  }

  a {
    font-family: $font-mono;
    font-size: $text-sm;
  }

  .v1 {
  margin-left: auto;

  @media (max-width: 560px) {
    margin-left: 0;
    width: 100%;
    margin-top: $space-s;
  }

  a {
    color: $color-text-muted;
  }
}
</style>  