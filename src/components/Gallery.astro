---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryItem {
  id: string;
  image: ImageMetadata;
  alt: string;
}

interface Props {
  items: GalleryItem[];
  height?: number;
}

const { items, height = 340 } = Astro.props;
---

<div class="gallery" data-gallery style={`--height: ${height}px;`}>
  <ul class="track">
    {
      items.map((item) => (
        <li class="item">
          <button
            type="button"
            class="trigger"
            data-gallery-item={item.id}
            aria-label={`Open ${item.alt}`}
          >
            <Image
              src={item.image}
              alt={item.alt}
              widths={[400, 800, 1200]}
              sizes="(max-width: 768px) 70vw, 480px"
              loading="lazy"
              decoding="async"
            />
          </button>
        </li>
      ))
    }
  </ul>
</div>

<style lang="scss">
  .gallery {
    width: 100%;
    height: var(--height);
    max-height: 60vh;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;

    // Hide scrollbar cross-browser
    scrollbar-width: none;
    &::-webkit-scrollbar {
      display: none;
    }
  }

  .track {
    display: flex;
    align-items: center;
    gap: $space-xs;
    list-style: none;
    padding: 0;
    margin: 0;
    height: 100%;
    width: max-content;
  }

  .item {
    height: 100%;
    flex-shrink: 0;
    scroll-snap-align: center;
  }

  .trigger {
    height: 100%;
    display: block;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;

    img {
      height: 100%;
      width: auto;
      max-width: none;
      object-fit: contain;
      display: block;
      transition: opacity 0.3s ease;
    }

    &:hover img {
      opacity: 0.85;
    }
  }
</style>