---
// Modal shell — content injected at runtime by JS.
// Two modes: 'full' (works projects) and 'grid' (playground).
---

<dialog class="modal" data-modal tabindex="-1">
  <!-- Full mode: project card -->
  <div class="mode-full" data-modal-full hidden>
    <div class="card">
      <header class="card-head">
        <div class="card-title-row">
          <h2 class="card-title" data-modal-title></h2>
          <span class="card-year" data-modal-year></span>
        </div>
        <p class="card-desc" data-modal-desc></p>
        <p class="card-meta" data-modal-meta></p>
      </header>
      <div class="card-gallery" data-modal-gallery></div>
      <div class="card-links">
        <a class="card-link" href="#" data-modal-link target="_blank" rel="noopener noreferrer" hidden>
  Visit live site &rarr;
</a>
<a class="card-link" href="#" data-modal-repo target="_blank" rel="noopener noreferrer" hidden>
  View source &rarr;
</a>
      </div>
    </div>
  </div>

  <!-- Grid mode: playground masonry -->
  <div class="mode-grid" data-modal-grid hidden>
    <div class="grid-masonry" data-modal-masonry></div>
  </div>

  <button type="button" class="modal-close" data-modal-close aria-label="Close">
    &times;
  </button>
</dialog>

<style lang="scss">
  .modal {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    margin: 0;
    color: $color-text;
    opacity: 0;
    transition:
      opacity $duration-base $ease-out-soft,
      overlay $duration-base $ease-out-soft allow-discrete,
      display $duration-base $ease-out-soft allow-discrete;

    &[open] {
      opacity: 1;

      @starting-style {
        opacity: 0;
      }
    }

    &::backdrop {
      background: rgba(0, 0, 0, 0);
      backdrop-filter: blur(0);
      transition:
        background $duration-base $ease-out-soft,
        backdrop-filter $duration-base $ease-out-soft;
    }

    &[open]::backdrop {
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(8px);
    }

    @media (prefers-reduced-motion: reduce) {
      transition: none;
      &::backdrop {
        transition: none;
      }
    }
  }

  // ---- Full mode ----
  .mode-full {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: $space-l 24px;

    @media (max-width: 560px) {
      padding: $space-m 16px;
    }
  }

  .card {
    background: $color-background;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    max-width: $max-main;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: $space-l;
    display: flex;
    flex-direction: column;
    gap: $space-m;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity $duration-base $ease-out-soft,
      transform $duration-base $ease-out-soft;
    transition-delay: 100ms;

    scrollbar-width: none;
    &::-webkit-scrollbar {
      display: none;
    }

    @media (max-width: 560px) {
      padding: $space-m;
    }
  }

  .modal[open] .card {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .modal[open] .card {
      transition: none;
      transform: none;
    }
  }

  // ---- Card head ----
  .card-head {
    display: flex;
    flex-direction: column;
    gap: $space-s;
  }

  .card-title-row {
    display: flex;
    align-items: baseline;
    gap: $space-s;
    flex-wrap: wrap;
  }

  .card-title {
    font-family: $font-mono;
    font-size: $text-base;
    font-weight: $weight-medium;
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .card-year {
    font-family: $font-mono;
    font-size: $text-sm;
    color: $color-text-muted;

    &:empty {
      display: none;
    }
  }

  .card-desc {
    font-family: $font-sans;
    font-size: $text-base;
    line-height: $leading-normal;
    color: $color-text-muted;
    margin: 0;
  }

  .card-meta {
    font-family: $font-mono;
    font-size: $text-sm;
    color: $color-text-muted;
    margin: 0;

    &:empty {
      display: none;
    }
  }

  .card-concept {
    font-family: $font-mono;
    font-size: $text-sm;
    color: $color-text-muted;
    font-style: italic;
    margin: 0;
  }

  // ---- Gallery ----
  .card-gallery {
    display: flex;
    flex-direction: column;
    gap: $space-s;

    :global(img) {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 2px;
    }
  }

  // ---- Links ----
  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: $space-m;
  }

  .card-link {
    font-family: $font-mono;
    font-size: $text-sm;
    align-self: flex-start;
  }

  // ---- Grid mode ----
  .mode-grid {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: $space-l 24px;

    scrollbar-width: none;
    &::-webkit-scrollbar {
      display: none;
    }
  }

  // ---- Close ----
  .modal-close {
    position: fixed;
    top: $space-m;
    right: $space-m;
    font-size: 1.5rem;
    line-height: 1;
    color: $color-text;
    z-index: 1;
  }
</style>

<script>
  const modal = document.querySelector<HTMLDialogElement>('[data-modal]');

  if (modal) {
    const fullMode = modal.querySelector<HTMLElement>('[data-modal-full]');
    const gridMode = modal.querySelector<HTMLElement>('[data-modal-grid]');
    const titleEl = modal.querySelector<HTMLElement>('[data-modal-title]');
    const yearEl = modal.querySelector<HTMLElement>('[data-modal-year]');
    const descEl = modal.querySelector<HTMLElement>('[data-modal-desc]');
    const metaEl = modal.querySelector<HTMLElement>('[data-modal-meta]');
    const conceptEl = modal.querySelector<HTMLElement>('[data-modal-concept]');
    const galleryEl = modal.querySelector<HTMLElement>('[data-modal-gallery]');
    const linkEl = modal.querySelector<HTMLAnchorElement>('[data-modal-link]');
    const repoEl = modal.querySelector<HTMLAnchorElement>('[data-modal-repo]');

    const open = () => {
      if (!modal.open) modal.showModal();
      document.body.style.overflow = 'hidden';
      modal.focus();
    };

    const close = () => {
      modal.close();
    };

    const readField = (content: DocumentFragment, name: string): string =>
      content.querySelector(`[data-field="${name}"]`)?.textContent?.trim() ?? '';

    const openFull = (projectId: string) => {
      const tpl = document.querySelector<HTMLTemplateElement>(
        `template[data-project="${projectId}"]`
      );
      if (!tpl || !fullMode || !gridMode) return;

      const content = tpl.content;
      const title = readField(content, 'title');
      const year = readField(content, 'year');
      const desc = readField(content, 'desc');
      const role = readField(content, 'role');
      const techStr = readField(content, 'tech');
      const status = readField(content, 'status');
      const link = readField(content, 'link');
      const repo = readField(content, 'repo');
      const images = content.querySelector('[data-field="images"]');

      const tech = techStr ? techStr.split('|').filter(Boolean) : [];

      // Title + year
      if (titleEl) titleEl.textContent = title;
      if (yearEl) yearEl.textContent = year;

      // Description
      if (descEl) descEl.textContent = desc;

      // Inline meta: "Role: X · Stack: A, B, C"
      if (metaEl) {
        const parts: string[] = [];
        if (role) parts.push(`Role: ${role}`);
        if (tech.length) parts.push(`Stack: ${tech.join(', ')}`);
        metaEl.textContent = parts.join(' · ');
      }

      // Concept note: shown only when status === 'concept'
      if (conceptEl) conceptEl.hidden = status !== 'concept';

      // Gallery
      if (galleryEl && images) {
        galleryEl.replaceChildren(images.cloneNode(true));
      }

      // Live + repo links
      if (linkEl) {
        if (link) {
          linkEl.href = link;
          linkEl.hidden = false;
        } else {
          linkEl.hidden = true;
        }
      }
      if (repoEl) {
        if (repo) {
          repoEl.href = repo;
          repoEl.hidden = false;
        } else {
          repoEl.hidden = true;
        }
      }

      gridMode.hidden = true;
      fullMode.hidden = false;
      open();

      const card = modal.querySelector<HTMLElement>('.card');
      requestAnimationFrame(() => {
        if (card) card.scrollTop = 0;
      });
    };

    // Wire WORKS triggers
    document.querySelectorAll<HTMLAnchorElement>('a[data-work]').forEach((link) => {
      link.addEventListener('click', (e) => {
        // Let modified clicks through — new tab, etc. — to the real page
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.button !== 0) return;
        e.preventDefault();
        const id = link.dataset.work;
        if (id) openFull(id);
      });
    });

    // Close: button
    modal.querySelector('[data-modal-close]')?.addEventListener('click', close);

    // Explicit Esc handling — Safari's native dialog Esc is unreliable
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.open) {
        e.preventDefault();
        close();
      }
    });

    // Close: backdrop
    fullMode?.addEventListener('click', (e) => {
      if (e.target === fullMode) close();
    });
    gridMode?.addEventListener('click', (e) => {
      if (e.target === gridMode) close();
    });

    // Restore scroll on any close
    modal.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  }
</script>