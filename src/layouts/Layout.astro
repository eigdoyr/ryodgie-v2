---
import '../styles/reset.scss';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-mono/400.css';
import '@fontsource/dm-mono/500.css';
import '../styles/typography.scss';
import '../styles/global.scss';

import Avatar from '../components/Avatar.astro';
import Header from '../components/Header.astro';
import FolderLink from '../components/FolderLink.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Modal from '../components/Modal.astro';
import { profile, socials } from '../data/site';

interface Props {
  title: string;
  description?: string;
}

const { title, description = profile.description } = Astro.props;

const pathname = Astro.url.pathname;
const isHome = pathname === '/';

const hasGallery = Astro.slots.has('gallery');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <>
    <main class="layout">
      <div class="top">
        <Avatar />
        <div class="header-wrap">
          <Header name={profile.name} role={profile.role} />
        </div>
      </div>
      {
        hasGallery && (
          <div class="gallery">
            <slot name="gallery" />
          </div>
        )
      }
      <div class="body">
        <slot />
      </div>
      <nav class="folders">
        <FolderLink
          href="/design-archives"
          label="Design Archives"
          active={pathname.startsWith('/design-archives')}
        />
        <FolderLink
          href="/playground"
          label="Playground"
          active={pathname.startsWith('/playground')}
        />
        {!isHome && <FolderLink href="/" label="Home" />}
      </nav>
      <div class="socials-wrap">
        <SocialLinks links={socials} />
      </div>
    </main>
    <Modal />
  </body>
</html>

<style lang="scss">
  .layout {
  min-height: 100vh;
  padding: $space-l 24px;
  display: flex;
  flex-direction: column;
  align-items: center;

  @media (max-height: #{$bp-tall - 1px}) {
    padding-bottom: $space-l * 2;
  }
}

  // 592px-constrained sections
  .top,
  .body,
  .folders,
  .socials-wrap {
    width: 100%;
    max-width: $max-main;
  }

  .header-wrap {
    margin-top: $space-s;
  }

  // Gallery breaks out to full viewport width
  .gallery {
    width: 100%;
    margin-top: $space-l;
  }

  .body:not(:empty) {
    margin-top: $space-l;
  }

  .folders {
    margin-top: $space-l;
    display: flex;
    flex-direction: column;
    gap: $space-xs;
  }

  .socials-wrap {
    margin-top: $space-l;
  }
</style>